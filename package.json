{
  "name": "baja-entrepreneur",
  "version": "1.0.0",
  "description": "Multi-agent AI system for Baja Entrepreneur content creation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node --esm src/index.ts",
    "orchestrator": "npx ts-node --esm src/agents/orchestrator.ts",
    "research": "npx ts-node --esm src/agents/research.ts",
    "writer": "npx ts-node --esm src/agents/writer.ts",
    "events": "npx ts-node --esm src/agents/events.ts"
  },
  "keywords": ["ai", "agents", "content", "baja", "entrepreneur"],
  "author": "AppManTexas",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
